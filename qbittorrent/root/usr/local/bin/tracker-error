#!/bin/bash

tag_name="TrackerError"

## 找到tracker出错的种子
. /usr/local/bin/share
cmd_curl_post -d "hashes=all&tags=${tag_name}" ${api_url_base}/torrents/removeTags
add_hashes=($(cmd_curl "${api_url_base}/sync/maindata" | jq -r '.torrents | to_entries[] | select(.value.has_tracker_error == true) | .key'))

## 调整标签
if [[ -n ${add_hashes[@]} ]]; then
    echo "hashes=$(echo "${add_hashes[@]}" | perl -pe 's| |\||g')&tags=${tag_name}" | cmd_curl_post -d @- ${api_url_base}/torrents/addTags

    ## 发送通知
    TRACKER_ERROR_COUNT_MIN=${TRACKER_ERROR_COUNT_MIN:-3}
    if [[ ${#add_hashes[@]} -ge $TRACKER_ERROR_COUNT_MIN ]]; then
        notify "tracker出错数量超过阈值" "主机：${HOSTNAME}\n时间：$(date +'%Y-%m-%d %H:%M:%S')\n注意：当前有${#add_hashes[@]}个种子tracker出错，建议检查一下\n说明：您收到本通知是因为您设置了通知阈值TRACKER_ERROR_COUNT_MIN=${TRACKER_ERROR_COUNT_MIN}(默认值:3)"
    fi
fi
